@page "{id:int}"
@model ExpenseManagement.Pages.Expenses.DetailsModel
@{
    ViewData["Title"] = $"Expense #{Model.Expense?.ExpenseId}";
    ViewData["ActivePage"] = "Expenses";
    var expense = Model.Expense!;
    var managers = Model.Users.Where(u => u.RoleName == "Manager").ToList();
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center mb-4">
            <a href="/Expenses" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div class="flex-grow-1">
                <h1 class="h3 mb-0 fw-bold"><i class="bi bi-receipt me-2 text-primary"></i>Expense #@expense.ExpenseId</h1>
                <p class="text-muted mb-0 small">Submitted by @expense.UserName</p>
            </div>
            @{
                var (statusBadge, statusIcon) = expense.StatusName switch {
                    "Draft"     => ("bg-secondary", "bi-pencil"),
                    "Submitted" => ("bg-warning text-dark", "bi-clock"),
                    "Approved"  => ("bg-success", "bi-check-circle-fill"),
                    "Rejected"  => ("bg-danger", "bi-x-circle-fill"),
                    _           => ("bg-secondary", "bi-question")
                };
            }
            <span class="badge @statusBadge fs-6 px-3 py-2">
                <i class="bi @statusIcon me-1"></i>@expense.StatusName
            </span>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-semibold">Expense Details</h5>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="text-muted small fw-semibold text-uppercase">Employee</label>
                        <p class="fw-semibold mb-0"><i class="bi bi-person me-1"></i>@expense.UserName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small fw-semibold text-uppercase">Category</label>
                        <p class="fw-semibold mb-0"><span class="badge bg-light text-dark border">@expense.CategoryName</span></p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small fw-semibold text-uppercase">Amount</label>
                        <p class="fw-bold fs-4 text-success mb-0">£@expense.AmountDecimal.ToString("N2") <span class="text-muted fs-6">@expense.Currency</span></p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small fw-semibold text-uppercase">Expense Date</label>
                        <p class="fw-semibold mb-0"><i class="bi bi-calendar3 me-1"></i>@expense.ExpenseDate.ToString("dd MMMM yyyy")</p>
                    </div>
                    @if (!string.IsNullOrEmpty(expense.Description))
                    {
                        <div class="col-12">
                            <label class="text-muted small fw-semibold text-uppercase">Description</label>
                            <p class="mb-0">@expense.Description</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(expense.ReceiptFile))
                    {
                        <div class="col-12">
                            <label class="text-muted small fw-semibold text-uppercase">Receipt</label>
                            <p class="mb-0"><i class="bi bi-paperclip me-1"></i><code>@expense.ReceiptFile</code></p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Timeline -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 fw-semibold">Timeline</h5>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <div class="d-flex mb-3">
                        <div class="flex-shrink-0 me-3"><span class="badge bg-secondary rounded-circle p-2"><i class="bi bi-plus-circle"></i></span></div>
                        <div><div class="fw-semibold">Created</div><div class="text-muted small">@expense.CreatedAt.ToString("dd MMM yyyy HH:mm") UTC</div></div>
                    </div>
                    @if (expense.SubmittedAt.HasValue)
                    {
                        <div class="d-flex mb-3">
                            <div class="flex-shrink-0 me-3"><span class="badge bg-warning text-dark rounded-circle p-2"><i class="bi bi-send"></i></span></div>
                            <div><div class="fw-semibold">Submitted for Approval</div><div class="text-muted small">@expense.SubmittedAt.Value.ToString("dd MMM yyyy HH:mm") UTC</div></div>
                        </div>
                    }
                    @if (expense.ReviewedAt.HasValue)
                    {
                        <div class="d-flex mb-3">
                            <div class="flex-shrink-0 me-3">
                                <span class="badge @(expense.StatusName == "Approved" ? "bg-success" : "bg-danger") rounded-circle p-2">
                                    <i class="bi @(expense.StatusName == "Approved" ? "bi-check" : "bi-x")"></i>
                                </span>
                            </div>
                            <div>
                                <div class="fw-semibold">@expense.StatusName by @expense.ReviewedByName</div>
                                <div class="text-muted small">@expense.ReviewedAt.Value.ToString("dd MMM yyyy HH:mm") UTC</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex flex-wrap gap-2">
                @if (expense.StatusName == "Draft")
                {
                    <a href="/Expenses/Edit/@expense.ExpenseId" class="btn btn-outline-secondary">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <form method="post" asp-page-handler="Submit" asp-route-id="@expense.ExpenseId" class="d-inline">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-send me-1"></i>Submit for Approval
                        </button>
                    </form>
                }
                @if (expense.StatusName == "Submitted" && managers.Any())
                {
                    <form method="post" asp-page-handler="Approve" asp-route-id="@expense.ExpenseId" class="d-inline">
                        <input type="hidden" name="reviewedBy" value="@managers.First().UserId" />
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Approve
                        </button>
                    </form>
                    <form method="post" asp-page-handler="Reject" asp-route-id="@expense.ExpenseId" class="d-inline">
                        <input type="hidden" name="reviewedBy" value="@managers.First().UserId" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-x-circle me-1"></i>Reject
                        </button>
                    </form>
                }
                <a href="/Expenses" class="btn btn-outline-secondary ms-auto">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>
