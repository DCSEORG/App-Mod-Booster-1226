@page
@model ExpenseManagement.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-1 fw-bold text-dark"><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard</h1>
                <p class="text-muted mb-0">Overview of all expense activity</p>
            </div>
            <a href="/Expenses/Create" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>New Expense
            </a>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="display-6 fw-bold text-primary mb-1">@Model.Stats.TotalExpenses</div>
                <div class="text-muted small fw-semibold text-uppercase">Total</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="display-6 fw-bold text-secondary mb-1">@Model.Stats.DraftCount</div>
                <div class="text-muted small fw-semibold text-uppercase">Draft</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="display-6 fw-bold text-warning mb-1">@Model.Stats.SubmittedCount</div>
                <div class="text-muted small fw-semibold text-uppercase">Pending</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="display-6 fw-bold text-success mb-1">@Model.Stats.ApprovedCount</div>
                <div class="text-muted small fw-semibold text-uppercase">Approved</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <div class="display-6 fw-bold text-danger mb-1">@Model.Stats.RejectedCount</div>
                <div class="text-muted small fw-semibold text-uppercase">Rejected</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6">
        <div class="card border-0 shadow-sm h-100 bg-success bg-opacity-10">
            <div class="card-body text-center py-4">
                <div class="display-6 fw-bold text-success mb-1">£@Model.Stats.TotalApprovedAmount.ToString("N2")</div>
                <div class="text-muted small fw-semibold text-uppercase">Approved £</div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-4 mb-4">
    <div class="col-md-3 col-6">
        <a href="/Expenses?status=2" class="card border-0 shadow-sm text-decoration-none h-100 action-card">
            <div class="card-body text-center py-4">
                <i class="bi bi-clock-history display-5 text-warning mb-2 d-block"></i>
                <div class="fw-semibold">Pending Review</div>
                <div class="text-muted small">@Model.Stats.SubmittedCount awaiting approval</div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a href="/Expenses/Create" class="card border-0 shadow-sm text-decoration-none h-100 action-card">
            <div class="card-body text-center py-4">
                <i class="bi bi-plus-circle display-5 text-primary mb-2 d-block"></i>
                <div class="fw-semibold">Submit Expense</div>
                <div class="text-muted small">Add a new expense claim</div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a href="/Expenses" class="card border-0 shadow-sm text-decoration-none h-100 action-card">
            <div class="card-body text-center py-4">
                <i class="bi bi-list-ul display-5 text-info mb-2 d-block"></i>
                <div class="fw-semibold">All Expenses</div>
                <div class="text-muted small">View and manage all claims</div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <a href="/chat" class="card border-0 shadow-sm text-decoration-none h-100 action-card">
            <div class="card-body text-center py-4">
                <i class="bi bi-chat-dots display-5 text-success mb-2 d-block"></i>
                <div class="fw-semibold">AI Assistant</div>
                <div class="text-muted small">Ask questions about expenses</div>
            </div>
        </a>
    </div>
</div>

<!-- Recent Expenses -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 fw-semibold"><i class="bi bi-clock me-2 text-primary"></i>Recent Expenses</h5>
        <a href="/Expenses" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        @if (Model.Stats.RecentExpenses.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Employee</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th class="pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model.Stats.RecentExpenses)
                        {
                            <tr>
                                <td class="ps-4"><span class="badge bg-secondary">#@e.ExpenseId</span></td>
                                <td><i class="bi bi-person me-1 text-muted"></i>@e.UserName</td>
                                <td><span class="badge bg-light text-dark">@e.CategoryName</span></td>
                                <td class="text-truncate" style="max-width:200px;" title="@e.Description">@e.Description</td>
                                <td class="fw-semibold">£@e.AmountDecimal.ToString("N2")</td>
                                <td>@e.ExpenseDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @{
                                        var badgeClass = e.StatusName switch {
                                            "Draft" => "bg-secondary",
                                            "Submitted" => "bg-warning text-dark",
                                            "Approved" => "bg-success",
                                            "Rejected" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@e.StatusName</span>
                                </td>
                                <td class="pe-4">
                                    <a href="/Expenses/Details/@e.ExpenseId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox display-4 d-block mb-3"></i>
                <p>No expenses found. <a href="/Expenses/Create">Create your first expense</a>.</p>
            </div>
        }
    </div>
</div>
