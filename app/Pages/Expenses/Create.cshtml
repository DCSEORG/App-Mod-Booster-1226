@page
@model ExpenseManagement.Pages.Expenses.CreateModel
@{
    ViewData["Title"] = "New Expense";
    ViewData["ActivePage"] = "Expenses";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex align-items-center mb-4">
            <a href="/Expenses" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h1 class="h3 mb-0 fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>New Expense</h1>
                <p class="text-muted mb-0 small">Fill in the details below to submit an expense claim</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.UserId" class="form-label fw-semibold">Employee</label>
                            <select asp-for="Input.UserId" class="form-select" required>
                                @foreach (var u in Model.Users)
                                {
                                    <option value="@u.UserId">@u.UserName (@u.RoleName)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.CategoryId" class="form-label fw-semibold">Category</label>
                            <select asp-for="Input.CategoryId" class="form-select" required>
                                @foreach (var c in Model.Categories)
                                {
                                    <option value="@c.CategoryId">@c.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Amount (£)</label>
                            <div class="input-group">
                                <span class="input-group-text">£</span>
                                <input type="number" class="form-control" id="amountDisplay" 
                                       placeholder="0.00" step="0.01" min="0.01" required
                                       onchange="updateAmountMinor(this.value)" />
                                <input type="hidden" asp-for="Input.AmountMinor" id="amountMinor" />
                            </div>
                            <div class="form-text">Enter amount in pounds (e.g., 12.50)</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.ExpenseDate" class="form-label fw-semibold">Expense Date</label>
                            <input asp-for="Input.ExpenseDate" type="date" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label asp-for="Input.Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="3" 
                                      placeholder="Describe the business purpose of this expense..."></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Input.ReceiptFile" class="form-label fw-semibold">Receipt Reference <span class="text-muted fw-normal">(optional)</span></label>
                            <input asp-for="Input.ReceiptFile" class="form-control" placeholder="/receipts/my-receipt.pdf" />
                            <div class="form-text">Reference path or URL for the receipt</div>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/Expenses" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save me-2"></i>Save as Draft
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function updateAmountMinor(val) {
    var minor = Math.round(parseFloat(val) * 100);
    document.getElementById('amountMinor').value = isNaN(minor) ? 0 : minor;
}
// Set default date
document.addEventListener('DOMContentLoaded', function() {
    var today = new Date().toISOString().split('T')[0];
    var dateField = document.querySelector('input[name="Input.ExpenseDate"]');
    if (dateField && !dateField.value) dateField.value = today;
});
</script>
}
